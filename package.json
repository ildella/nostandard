{
  "name": "eslint-nostandard",
  "version": "0.7.0-0",
  "description": "Eslint standard for bad people.",
  "license": "MIT",
  "type": "module",
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7",
  "homepage": "https://github.com/ildella/nostandard",
  "repository": {
    "type": "git",
    "url": "git://github.com/ildella/nostandard.git"
  },
  "author": {
    "name": "Daniele Dellafiore",
    "url": "https://linktr.ee/ildella/"
  },
  "keywords": [
    "eslint",
    "configuration"
  ],
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "exports": {
    ".": "./src/index.js",
    "./svelte": "./src/configs/svelte.js",
    "./vitest": "./src/configs/vitest.js",
    "./import-x": "./src/configs/import-x.js",
    "./sonarjs": "./src/configs/sonarjs.js",
    "./functional-unicorn": "./src/configs/functional-unicorn.js",
    "./playwright": "./src/configs/playwright.js"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "check:lint": "eslint --report-unused-disable-directives .",
    "lint": "eslint . --cache --max-warnings 1",
    "lint.nocache": "eslint . --max-warnings 0",
    "lint.inspect": "npx @eslint/config-inspector",
    "test": "vitest",
    "test.ci": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@eslint/js": "^9",
    "@stylistic/eslint-plugin-js": "^4",
    "globals": "^16"
  },
  "devDependencies": {
    "@vitest/eslint-plugin": "1.6.17",
    "eslint": "^9",
    "eslint-plugin-functional": "10.0.0",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-playwright": "2.10.4",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-svelte": "3.17.1",
    "eslint-plugin-unicorn": "60.0.0",
    "svelte": "5.55.5",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "eslint-plugin-functional": "^10.0.0",
    "eslint-plugin-import-x": "^4.16.0",
    "eslint-plugin-playwright": "^2.10.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-unicorn": "^60.0.0"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-functional": {
      "optional": true
    },
    "eslint-plugin-import-x": {
      "optional": true
    },
    "eslint-plugin-playwright": {
      "optional": true
    },
    "eslint-plugin-sonarjs": {
      "optional": true
    },
    "eslint-plugin-unicorn": {
      "optional": true
    }
  },
  "stableVersion": "0.6.0"
